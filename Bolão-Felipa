<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bolão Felipa | Brasileirão 2026</title>
    <style>
        :root {
            --primary: #007b3e;
            --secondary: #fbc02d;
            --glass: rgba(255, 255, 255, 0.15);
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #004d26 0%, #00220f 100%);
            color: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
        }

        .glass-card {
            background: var(--glass);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            padding: 30px;
            width: 100%;
            max-width: 600px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            margin-bottom: 30px;
        }

        h1 { text-align: center; color: var(--secondary); text-transform: uppercase; letter-spacing: 2px; }
        h2 { border-bottom: 2px solid var(--secondary); padding-bottom: 10px; margin-top: 0; }

        .jogo-linha {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 15px 0;
            padding: 10px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 10px;
        }

        .time { font-weight: bold; width: 35%; }
        .time-dir { text-align: right; }
        
        input[type="number"] {
            width: 45px;
            height: 35px;
            text-align: center;
            border-radius: 8px;
            border: none;
            font-size: 18px;
            font-weight: bold;
        }

        .btn-enviar {
            width: 100%;
            background: var(--secondary);
            color: #000;
            border: none;
            padding: 15px;
            border-radius: 10px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 20px;
        }

        .btn-enviar:hover { transform: scale(1.02); background: #f9a825; }

        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        th { text-align: left; color: var(--secondary); padding: 10px; }
        td { padding: 10px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
        .posicao { font-weight: bold; color: var(--secondary); }
    </style>
</head>
<body>

    <div class="glass-card">
        <h1>🏆 Bolão Felipa</h1>
        <p style="text-align: center;">Rodada 5 - Brasileirão 2026</p>

        <form id="formPalpites">
            <input type="text" placeholder="Seu Nome Completo" required style="width: 95%; padding: 10px; margin-bottom: 20px; border-radius: 8px; border: none;">

            <div class="jogo-linha">
                <span class="time">Flamengo</span>
                <input type="number" name="fla" value="0" min="0">
                <span>x</span>
                <input type="number" name="cru" value="0" min="0">
                <span class="time time-dir">Cruzeiro</span>
            </div>

            <div class="jogo-linha">
                <span class="time">Vasco</span>
                <input type="number" name="vas" value="0" min="0">
                <span>x</span>
                <input type="number" name="pal" value="0" min="0">
                <span class="time time-dir">Palmeiras</span>
            </div>

            <div class="jogo-linha">
                <span class="time">Corinthians</span>
                <input type="number" name="cor" value="0" min="0">
                <span>x</span>
                <input type="number" name="cri" value="0" min="0">
                <span class="time time-dir">Coritiba</span>
            </div>

            <button type="submit" class="btn-enviar">ENVIAR PALPITES</button>
        </form>
    </div>

    <div class="glass-card">
        <h2>📊 Ranking Geral</h2>
        <table>
            <thead>
                <tr>
                    <th>Pos</th>
                    <th>Apostador</th>
                    <th>Pts</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="posicao">1º</td>
                    <td>Lucas Barber</td>
                    <td>15</td>
                </tr>
                <tr>
                    <td class="posicao">2º</td>
                    <td>Felipa</td>
                    <td>12</td>
                </tr>
                <tr>
                    <td class="posicao">3º</td>
                    <td>João FPV</td>
                    <td>8</td>
                </tr>
            </tbody>
        </table>
    </div>

    <script>
    document.getElementById('formPalpites').onsubmit = function(e) {
        e.preventDefault();
        
        // Coleta o nome do apostador
        const nome = document.querySelector('input[placeholder="Seu Nome Completo"]').value;
        
        // Coleta os placares dos inputs
        const fla = document.getElementsByName('fla')[0].value;
        const cru = document.getElementsByName('cru')[0].value;
        
        const vas = document.getElementsByName('vas')[0].value;
        const pal = document.getElementsByName('pal')[0].value;
        
        const cor = document.getElementsByName('cor')[0].value;
        const cri = document.getElementsByName('cri')[0].value;

        // Monta a mensagem formatada
        const mensagem = `🏆 *PALPITES BOLÃO FELIPA*%0A` +
                         `👤 *Apostador:* ${nome}%0A%0A` +
                         `⚽ Flamengo ${fla} x ${cru} Cruzeiro%0A` +
                         `⚽ Vasco ${vas} x ${pal} Palmeiras%0A` +
                         `⚽ Corinthians ${cor} x ${cri} Coritiba`;

        // Substitua pelo SEU número de WhatsApp (com DDD)
        const meuWhatsapp = "5511999999999"; 
        
        window.open(`https://wa.me/${meuWhatsapp}?text=${mensagem}`);
        
        alert('Abrindo o WhatsApp para confirmar seu palpite...');
    };
</script>


</body>
</html>
